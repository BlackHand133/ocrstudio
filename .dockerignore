# ============================================================
# .dockerignore — files excluded from the Docker build context
# ============================================================

# Version control
.git
.gitignore

# Python caches & build artefacts
__pycache__
*.py[cod]
*.pyo
*.pyd
.Python
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
venv/
.venv/
env/

# Test artefacts
.pytest_cache/
.coverage
htmlcov/
*.log

# User data (mounted as volumes at runtime)
workspaces/
data/
*.json

# Large output directories
output/
output_det/
output_rec/

# Model weights (mounted as volume)
models/

# Development / editor files
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Backup / scratch files
back-up/
back up/
ซองยา-up/

# CI / docs not needed inside the image
.github/
docs/
