# OCR Studio — environment configuration
# Copy to `.env` (same folder as the compose file); docker compose reads it
# automatically. All values are optional.

# Host port to serve the app on (container always listens on 8000 internally).
WEB_PORT=8000

# Optional HTTP Basic auth — set BOTH to require a login before any access.
# Recommended when exposing the app beyond your own machine. Leave commented
# out to disable (single-user, no auth).
#OCR_USER=admin
#OCR_PASS=change-me

# OCR runtime profile: cpu (default) or gpu. Usually leave unset.
#OCR_PROFILE=cpu
